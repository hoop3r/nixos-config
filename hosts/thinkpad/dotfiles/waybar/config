{
    "height": 30, 
    "layer": "top",
    "margin-top": 6,
    "margin-left": 10,
    "margin-bottom": 0,
    "margin-right": 10,
    "spacing": 5, 
    "modules-left": [
        "custom/launcher",
        "cpu",
        "memory",
        "hyprland/workspaces",
        "custom/weather"
    ],
    "modules-center": [
        "custom/spotify"
    ],
    "modules-right": [
        "tray",
        "backlight",
        "pulseaudio",
        "network",
	    "bluetooth",
        "battery",
        "clock",
        "custom/power-menu"
    ],
    "hyprland/workspaces": {
        "format": "{icon}",
        "on-click": "activate",
        "format-icons": {
            "1": "яДС ",
            "2": "яДС ",
            "3": "яДС ",
            "4": "яДС ",
            "5": "яДС ",
            "urgent": "яБк ",
            "active": "яДС ",
            "default": "яДС "
        }
    },
    "hyprland/window": {
        "format": "{}"
    },
    "tray": {
        "spacing": 0
    },
    "clock": {
        "format": "<span color='#bf616a'>яАЧ </span>{:%I:%M %p}",
        "format-alt": "<span color='#bf616a'>яБ│ </span>{:%a %b %d}",
        "tooltip-format": "<big>{:%B %Y}</big>\n<tt><small>{calendar}</small></tt>"
    },
    "cpu": {
        "interval": 10,
        "format": "яЛЫ {}%",
        "max-length": 10,
        "on-click": ""
    },
    "memory": {
        "interval": 30,
        "format": "яШк {}%",
        "format-alt": "яС▓ {used:0.1f}G",
        "max-length": 10
    },
    "backlight": {
        "device": "eDP-1",
        "format": "{icon} {percent}%",
        "format-icons": [
            "юОН",
            "юПУ",
            "юПС",
            "юПП",
            "юПО",
            "юПН",
            "юПК",
            "юПИ",
            "юОЫ"
        ],
        "on-click": ""
    },
    "network": {
        "format-wifi": "яЗл  {signalStrength}%",
        "format-ethernet": "яЫ┐ wired",
        "on-click": "bash ~/.config/waybar/scripts/rofi-wifi-menu.sh",
        "format-disconnected": "Disconnected яБ▒ "
    },
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-bluetooth": "яАе яКФ {volume}%",
        "format-bluetooth-muted": "яД▒  яКФ",
        "format-muted": "яД▒ ",
        "format-icons": {
            "headphone": "яАе",
            "hands-free": "яЦР",
            "headset": "яЦР",
            "phone": "яВХ",
            "portable": "яВХ",
            "car": "яЖ╣",
            "default": [
                "яАж",
                "яАз",
                "яАи"
            ]
        },
        "on-click": "pavucontrol"
    },
    "bluetooth": {
        "on-click": "~/.config/waybar/scripts/rofi-bluetooth &",
        "format": "яКФ {status}"
    },
    "battery": {
        "bat": "BAT0",
        "adapter": "ADP0",
        "interval": 60,
        "states": {
            "warning": 30,
            "critical": 15
        },
        "max-length": 20,
        "format": "{icon} {capacity}%",
        "format-warning": "{icon} {capacity}%",
        "format-critical": "{icon} {capacity}%",
        "format-charging": "<span font-family='Font Awesome 6 Free'>яГз</span> {capacity}%",
        "format-plugged": "яЗж  {capacity}%",
        "format-alt": "{icon} {time}",
        "format-full": "яЗж  {capacity}%",
        "format-icons": [
            "яЙД ",
            "яЙГ ",
            "яЙВ ",
            "яЙБ ",
            "яЙА "
        ]
    },
    "custom/weather": {
        "exec": "/home/hoop3r/.config/waybar/scripts/weather.py",
        "restart-interval": 300,
        "return-type": "json",
        "on-click": "xdg-open https://weather.com/weather/today/l/e8302dd5e02091eb1972a2d77d7c7e4caf15cf0cb8bdbeede41fa87dec408b21"
    },
    "custom/spotify": {
        "exec": "mediaplayer",
        "format": " {} ",
        "return-type": "json",
        "on-click": "playerctl play-pause",
        "on-double-click-right": "playerctl next",
        "on-scroll-down": "playerctl previous"
    },
    "custom/power-menu": {
        "format": " <span color='#6a92d7'>тП╗ </span>",
        "on-click": "bash ~/.config/waybar/scripts/power-menu/powermenu.sh"
    },
    "custom/launcher": {
        "format": " <span color='#6a92d7'>яАВ </span>",
        "on-click": "rofi -show drun"
    }
}
